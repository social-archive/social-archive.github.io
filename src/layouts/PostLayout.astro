---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title: string;
	description?: string;
	author?: string;
	pubDate?: Date;
	image?: { url: string; alt?: string };
}

const { title, description, author, pubDate, image } = Astro.props;

const siteUrl = 'https://social-archive.github.io';
const articleJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  ...(description && { description }),
  ...(image?.url && { image: `${siteUrl}${image.url}` }),
  ...(pubDate && { datePublished: new Date(pubDate).toISOString() }),
  author: {
    '@type': 'Person',
    name: author ?? '소셜 아카이브',
  },
  publisher: {
    '@type': 'Organization',
    name: '소셜 아카이브',
    logo: {
      '@type': 'ImageObject',
      url: `${siteUrl}/logo.png`,
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `${siteUrl}${Astro.url.pathname}`,
  },
});
---

<Layout title={title} description={description} image={image?.url}>
	<script type="application/ld+json" set:html={articleJsonLd} />
	<Header />

	<main class="py-16">
		<article class="prose prose-lg prose-neutral max-w-none prose-headings:font-bold prose-h1:text-4xl prose-h2:text-2xl prose-p:text-lg prose-p:leading-relaxed">
			<h1 class="mb-4">{title}</h1>
			<div class="text-base text-neutral-500 mb-8">
				{pubDate && <time datetime={pubDate instanceof Date ? pubDate.toISOString() : String(pubDate)}>{pubDate instanceof Date ? pubDate.toLocaleDateString('ko-KR') : pubDate}</time>}
				{author && <span class="ml-2">· {author}</span>}
			</div>
			<slot />
		</article>
	</main>

	<Footer />
</Layout>
