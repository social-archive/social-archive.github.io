---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title: string;
	description?: string;
	pubDate?: Date;
	image: string;
}

const { title, description, pubDate, image } = Astro.props;
---

<Layout title={title} description={description} image={image}>
	<Header />

	<main class="py-16">
		<article class="max-w-3xl mx-auto">
			<div class="mb-6">
				<a href="/gallery/" class="text-sm text-neutral-500 hover:text-neutral-900">← 갤러리 목록</a>
			</div>
			<h1 class="text-3xl font-bold text-neutral-900 mb-2">{title}</h1>
			{pubDate && <p class="text-neutral-500 mb-8">{new Date(pubDate).toLocaleDateString('ko-KR')}</p>}
			<div class="rounded-lg overflow-hidden border border-neutral-200 mb-8">
				<img src={image} alt={title} class="w-full h-auto block" />
			</div>
			<div class="prose prose-lg prose-neutral max-w-none">
				<slot />
			</div>
		</article>
	</main>

	<Footer />
</Layout>
