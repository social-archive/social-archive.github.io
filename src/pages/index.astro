---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import YouTubeChannelEmbed from '../components/YouTubeChannelEmbed.astro';
import { getGalleryImagesFromPublic } from '../lib/gallery';
import dailyQuestParts from '../data/daily-quest-parts.json';

const galleryPreview = getGalleryImagesFromPublic().slice(0, 6);
---

<Layout title="소셜 아카이브" description="AI 놀이터">
	<Header />

	<section class="border-b border-neutral-200/80 bg-neutral-50 py-14 md:py-20 lg:py-24">
		<div class="max-w-[1680px] mx-auto px-4 sm:px-6 lg:px-10">
			<div class="grid grid-cols-1 gap-10 lg:grid-cols-10 lg:gap-12 lg:items-center">
				<div class="lg:col-span-3">
					<h1 class="text-3xl md:text-4xl lg:text-[2.75rem] font-bold text-neutral-900 leading-tight tracking-tight">
						AI 놀이터
					</h1>
				</div>
				<div class="lg:col-span-7 flex justify-center">
					<YouTubeChannelEmbed frameClass="lg:max-w-[min(100%,520px)]" />
				</div>
			</div>
		</div>
	</section>

	<section class="border-t border-neutral-200/80 bg-white py-12 md:py-16" aria-labelledby="inflearn-course-heading">
		<div class="max-w-[1680px] mx-auto px-4 sm:px-6 lg:px-10">
			<div
				class="rounded-2xl border border-emerald-200/80 bg-gradient-to-br from-emerald-50/95 via-white to-sky-50/50 p-6 md:p-8 shadow-sm"
			>
				<div class="flex flex-wrap items-center gap-2 mb-3">
					<span class="rounded-full bg-emerald-600 px-2.5 py-0.5 text-xs font-semibold uppercase tracking-wide text-white">
						Inflearn
					</span>
					<span class="text-sm text-neutral-600">입문 · 100 프롬프트 실습</span>
				</div>
				<h2 id="inflearn-course-heading" class="text-xl md:text-2xl font-bold text-neutral-900">
					AI 활용을 배우는 100가지 프롬프트 — 입문편
				</h2>
				<p class="mt-2 text-sm md:text-base text-neutral-600 max-w-3xl leading-relaxed">
					ChatGPT·Claude·Gemini를 처음 쓰는 분도, 직접 입력하며 익히는 실전 프롬프트로 생성형 AI 활용의 기초를 다질 수 있는 강의입니다. 무료 플랜으로도 수업을 따라가기에 충분해요.
				</p>
				<div class="mt-6 flex flex-wrap items-center gap-3">
					<a
						href="https://inf.run/jiXTj"
						class="inline-flex items-center justify-center rounded-sm bg-emerald-600 px-5 py-2.5 text-sm font-semibold text-white no-underline shadow-sm transition hover:bg-emerald-700"
						target="_blank"
						rel="noopener noreferrer"
					>
						인프런에서 강의 보기 →
					</a>
					<a
						href="/posts/inflearn-ai-100-prompts-beginner/"
						class="inline-flex items-center justify-center rounded-sm border border-neutral-300 bg-white px-5 py-2.5 text-sm font-medium text-neutral-900 no-underline transition hover:border-neutral-400 hover:bg-neutral-50"
					>
						공지 글 보기
					</a>
				</div>
			</div>
		</div>
	</section>

	<section class="border-t border-neutral-200/80 bg-white py-12 md:py-16" aria-labelledby="daily-quest-heading">
		<div class="max-w-[1680px] mx-auto px-4 sm:px-6 lg:px-10">
			<div
				class="rounded-2xl border border-amber-200/90 bg-gradient-to-br from-amber-50/90 to-orange-50/40 p-6 md:p-8 shadow-sm"
			>
				<div class="flex flex-wrap items-center gap-2 mb-3">
					<span class="rounded-full bg-amber-600 px-2.5 py-0.5 text-xs font-semibold uppercase tracking-wide text-white">
						Daily
					</span>
					<span id="dq-date" class="text-sm text-neutral-600"></span>
				</div>
				<h2 id="daily-quest-heading" class="text-xl md:text-2xl font-bold text-neutral-900">오늘의 일일 퀘스트</h2>
				<p class="mt-1 text-sm text-neutral-600">
					<strong class="font-medium text-neutral-800">미션·감정·창작 제약·표현</strong> 네 축이 그날의 날짜(한국시간)로 섞입니다. 일일 드로잉 챌린지·색 제약·한 컷 서사처럼 <strong class="font-medium text-neutral-800">구체적이고 겹치지 않게</strong> 고른 풀입니다. 같은 날은 모두 같은 조합입니다.
				</p>

				<div id="dq-content" class="mt-6 space-y-3">
					<h3 id="dq-title" class="text-lg md:text-xl font-semibold text-neutral-900"></h3>
					<p id="dq-desc" class="text-neutral-700 leading-relaxed max-w-3xl whitespace-pre-line"></p>
					<div class="rounded-lg border border-amber-100/80 bg-white/70 px-4 py-3">
						<p class="text-xs font-medium text-neutral-500 mb-1">영문 키워드 힌트</p>
						<p id="dq-keywords" class="text-sm text-neutral-800 font-mono break-words"></p>
					</div>
				</div>

				<p class="mt-6 text-sm text-neutral-600">
					프롬프트를 다듬을 땐 <a href="/archive/prompt-generator/" class="text-blue-700 underline decoration-blue-700/30 underline-offset-2 hover:text-neutral-900">자료실 · 프롬프트 제너레이터</a>를 써도 좋아요. 완성작은 <a href="https://cafe.naver.com/sarc100" class="text-blue-700 underline decoration-blue-700/30 underline-offset-2 hover:text-neutral-900" target="_blank" rel="noopener noreferrer">커뮤니티</a>(네이버 카페)에 올려 공유해 보세요.
				</p>

				<noscript>
					<p class="mt-4 text-sm text-amber-900">
						일일 퀘스트는 브라우저에서 날짜를 읽어 표시합니다. JavaScript를 켜 주세요.
					</p>
				</noscript>
			</div>
		</div>
	</section>

	<section class="border-t border-neutral-200/80 bg-neutral-50 py-16 md:py-24" aria-labelledby="home-gallery-heading">
		<div class="max-w-[1680px] mx-auto px-4 sm:px-6 lg:px-10">
			<div class="flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between mb-10 md:mb-12">
				<div>
					<h2 id="home-gallery-heading" class="text-2xl md:text-3xl font-semibold text-neutral-900 tracking-tight">
						갤러리
					</h2>
					<p class="mt-2 text-sm md:text-base text-neutral-500 max-w-xl">
						최근에 올라온 이미지입니다. 클릭하면 갤러리에서 크게 볼 수 있습니다.
					</p>
				</div>
				<a
					href="/gallery/"
					class="inline-flex shrink-0 items-center justify-center rounded-sm border border-neutral-300 bg-white px-5 py-2.5 text-sm font-medium text-neutral-900 no-underline transition hover:border-neutral-400 hover:bg-neutral-50"
				>
					갤러리 전체 보기 →
				</a>
			</div>

			{galleryPreview.length === 0 ? (
				<p class="rounded-sm border border-dashed border-neutral-300 bg-white px-6 py-10 text-center text-neutral-500 text-sm">
					<code class="rounded bg-neutral-100 px-1.5 py-0.5 text-xs text-neutral-700">public/images/gallery</code>
					에 이미지를 넣고 빌드하면 여기에 미리보기가 표시됩니다.
				</p>
			) : (
				<ul class="grid grid-cols-2 md:grid-cols-3 gap-4 md:gap-6 list-none p-0 m-0">
					{galleryPreview.map((item) => (
						<li>
							<a
								href="/gallery/"
								class="group block no-underline focus:outline-none focus-visible:ring-2 focus-visible:ring-neutral-900 focus-visible:ring-offset-2 focus-visible:ring-offset-neutral-50 rounded-sm"
								aria-label={`갤러리에서 ${item.title} 보기`}
							>
								<figure class="m-0 bg-white p-2 md:p-2.5 shadow-[0_2px_28px_-10px_rgba(0,0,0,0.12)] ring-1 ring-neutral-200/80 transition-shadow duration-300 group-hover:shadow-[0_8px_36px_-10px_rgba(0,0,0,0.16)]">
									<div class="relative aspect-[3/4] overflow-hidden bg-neutral-100">
										<img
											src={item.image}
											alt={item.title}
											class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.03]"
											loading="lazy"
											decoding="async"
										/>
										<figcaption class="absolute inset-x-0 bottom-0 flex flex-col justify-end p-3 pt-12 bg-gradient-to-t from-black/70 via-black/20 to-transparent pointer-events-none">
											<span class="text-[10px] md:text-[11px] font-medium text-white/95 line-clamp-2">{item.title}</span>
										</figcaption>
									</div>
								</figure>
							</a>
						</li>
					))}
				</ul>
			)}
		</div>
	</section>

	<Footer />

	<script define:vars={{ dailyQuestParts }}>
		function seoulDateKey() {
			const fmt = new Intl.DateTimeFormat('en-CA', {
				timeZone: 'Asia/Seoul',
				year: 'numeric',
				month: '2-digit',
				day: '2-digit',
			});
			const parts = fmt.formatToParts(new Date());
			const y = parts.find((p) => p.type === 'year')?.value ?? '2026';
			const m = parts.find((p) => p.type === 'month')?.value ?? '01';
			const d = parts.find((p) => p.type === 'day')?.value ?? '01';
			return `${y}-${m}-${d}`;
		}

		function hash32(str) {
			let h = 2166136261;
			for (let i = 0; i < str.length; i++) h = Math.imul(h ^ str.charCodeAt(i), 16777619);
			return h >>> 0;
		}

		/** 날짜 시드로 고정된 0~1 난수 */
		function mulberry32(seed) {
			return function () {
				let t = (seed += 0x6d2b79f5);
				t = Math.imul(t ^ (t >>> 15), t | 1);
				t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
				return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
			};
		}

		function pickDailyQuest(parts) {
			const key = seoulDateKey();
			const rng = mulberry32(hash32(key));
			const pick = (arr) => arr[Math.floor(rng() * arr.length)];

			const mission = pick(parts.missions);
			const emotion = pick(parts.emotions);
			const constraint = pick(parts.constraints);
			const execution = pick(parts.executions);

			const title = mission.ko;
			const desc = [
				`【감정·서사】 ${emotion.ko}`,
				`【창작 제약】 ${constraint.ko}`,
				`【표현】 ${execution.ko}`,
				`감정·제약·표현을 제목의 미션에 맞게 한 장에 녹여 내 보세요.`,
			].join('\n\n');
			const keywords = [mission.en, emotion.en, constraint.en, execution.en].join(', ');

			const dateLabel = new Intl.DateTimeFormat('ko-KR', {
				timeZone: 'Asia/Seoul',
				year: 'numeric',
				month: 'long',
				day: 'numeric',
				weekday: 'long',
			}).format(new Date());

			return { title, desc, keywords, key, dateLabel };
		}

		function renderDailyQuest() {
			const parts = dailyQuestParts;
			if (!parts?.missions?.length) return;
			const { title, desc, keywords, key, dateLabel } = pickDailyQuest(parts);
			const elDate = document.getElementById('dq-date');
			const elTitle = document.getElementById('dq-title');
			const elDesc = document.getElementById('dq-desc');
			const elKw = document.getElementById('dq-keywords');
			if (elDate) elDate.textContent = dateLabel + ' · KST';
			if (elTitle) elTitle.textContent = title;
			if (elDesc) elDesc.textContent = desc;
			if (elKw) elKw.textContent = keywords;
			document.getElementById('daily-quest-heading')?.setAttribute('data-quest-date', key);
		}

		renderDailyQuest();
	</script>
</Layout>
