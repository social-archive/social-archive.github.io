---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="소셜 아카이브" description="AI 인플루언서 엔터테인먼트 사업. AI 기반 가상 인플루언서 콘텐츠와 엔터테인먼트를 제공합니다.">
	<Header />

	<section class="py-24 md:py-32">
		<h1 class="text-4xl md:text-5xl font-bold text-neutral-900 leading-tight tracking-tight mb-6">
			소셜 아카이브
		</h1>
		<p class="text-xl md:text-2xl text-neutral-600">AI 인플루언서 엔터테인먼트 사업 · AI 기반 가상 인플루언서 콘텐츠와 엔터테인먼트를 제공합니다</p>
	</section>

	<Footer />
</Layout>
