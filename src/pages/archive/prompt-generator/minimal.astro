---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
---

<Layout
	title="미니멀 · 이미지 프롬프트 제너레이터 - 자료실"
	description="최소 입력으로 영문 이미지 프롬프트를 만듭니다."
>
	<Header />

	<main class="py-12 md:py-16">
		<div class="mb-8">
			<p class="mb-2 flex flex-wrap gap-x-4 gap-y-1 text-sm">
				<a href="/archive/" class="text-neutral-500 hover:text-neutral-900 no-underline">← 자료실</a>
				<a href="/archive/prompt-generator/" class="text-neutral-500 hover:text-neutral-900 no-underline">← 버전 목록</a>
			</p>
			<h1 class="mt-4 text-3xl md:text-4xl font-bold text-neutral-900">미니멀 · 프롬프트 제너레이터</h1>
			<p class="mt-2 text-neutral-600 max-w-2xl">주제 한 줄 + 프리셋 하나로 빠르게 조합합니다.</p>
		</div>

		<div class="grid gap-10 lg:grid-cols-2 lg:gap-12">
			<form class="space-y-6" autocomplete="off">
				<div>
					<label for="pgm-subject" class="block text-sm font-medium text-neutral-800 mb-1.5">주제 · 한 줄</label>
					<textarea
						id="pgm-subject"
						rows="3"
						class="w-full rounded-md border border-neutral-300 px-3 py-2 text-neutral-900 placeholder:text-neutral-400 focus:border-neutral-900 focus:outline-none focus:ring-1 focus:ring-neutral-900"
						placeholder="예: 고양이가 우주복을 입고 있다"
					></textarea>
				</div>
				<div>
					<label for="pgm-preset" class="block text-sm font-medium text-neutral-800 mb-1.5">프리셋</label>
					<select
						id="pgm-preset"
						class="w-full rounded-md border border-neutral-300 bg-white px-3 py-2 text-neutral-900 focus:border-neutral-900 focus:outline-none focus:ring-1 focus:ring-neutral-900"
					>
						<option value="photorealistic, natural lighting, detailed textures">실사 느낌</option>
						<option value="clean vector illustration, flat colors, bold shapes">플랫 일러스트</option>
						<option value="anime style, soft shading, expressive eyes">애니</option>
						<option value="cinematic lighting, film grain, moody color grade">시네마틱</option>
						<option value="3D render, subsurface scattering, studio HDRI">3D 렌더</option>
						<option value="watercolor texture, soft edges, paper grain">수채화 느낌</option>
					</select>
				</div>
				<label class="inline-flex items-center gap-2 text-sm text-neutral-700 cursor-pointer">
					<input id="pgm-quality" type="checkbox" class="rounded border-neutral-300" checked />
					품질 태그 (8k, masterpiece…)
				</label>
			</form>

			<div class="lg:sticky lg:top-8 h-fit space-y-3">
				<div class="flex items-center justify-between gap-2">
					<h2 class="text-sm font-semibold text-neutral-800">결과</h2>
					<button
						type="button"
						id="pgm-copy"
						class="rounded-md bg-neutral-900 px-3 py-1.5 text-sm font-medium text-white hover:bg-neutral-700"
					>
						복사
					</button>
				</div>
				<pre
					id="pgm-output"
					class="min-h-[10rem] whitespace-pre-wrap break-words rounded-lg border border-neutral-200 bg-white p-4 text-sm text-neutral-800 shadow-sm"
				></pre>
				<p id="pgm-hint" class="text-xs text-green-700 hidden">복사했습니다.</p>
			</div>
		</div>
	</main>

	<Footer />

	<script>
		const subject = document.getElementById('pgm-subject');
		const preset = document.getElementById('pgm-preset');
		const quality = document.getElementById('pgm-quality');
		const output = document.getElementById('pgm-output');
		const copyBtn = document.getElementById('pgm-copy');
		const hint = document.getElementById('pgm-hint');
		const q = 'masterpiece, best quality, highly detailed, sharp focus, 8k uhd';

		function build() {
			const parts = [];
			const s = subject?.value.trim();
			if (s) parts.push(s);
			const p = preset?.value.trim();
			if (p) parts.push(p);
			if (quality?.checked) parts.push(q);
			const t = parts.join(', ');
			if (output) output.textContent = t || '(주제를 입력하세요.)';
		}

		function wire() {
			for (const el of [subject, preset, quality]) {
				el?.addEventListener('input', build);
				el?.addEventListener('change', build);
			}
			copyBtn?.addEventListener('click', async () => {
				const text = output?.textContent?.trim() || '';
				if (!text || text.startsWith('(')) return;
				try {
					await navigator.clipboard.writeText(text);
					hint?.classList.remove('hidden');
					setTimeout(() => hint?.classList.add('hidden'), 2000);
				} catch {
					/* ignore */
				}
			});
			build();
		}
		wire();
	</script>
</Layout>
