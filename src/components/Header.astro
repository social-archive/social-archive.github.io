---
// Header redesigned for a center placement, but smaller
---

<header class="flex flex-col items-center gap-4 pt-10 pb-6 text-center">
	<div class="relative group">
		<div
			class="relative flex h-20 w-20 overflow-hidden items-center justify-center rounded-full bg-white border-2 border-black shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] transition-transform duration-200 group-hover:translate-x-[2px] group-hover:translate-y-[2px] group-hover:shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]"
		>
			<img src="/apple-touch-icon.png" alt="소셜아카이브 로고" class="w-full h-full object-cover" />
		</div>
	</div>

	<h1 class="text-2xl font-[900] tracking-tight text-black uppercase">
		소셜아카이브
	</h1>
</header>
