---
interface Props {
  href: string;
  title: string;
  subtitle?: string;
  description?: string;
  icon?: string;
  featured?: boolean;
}

const { href, title, subtitle, description, icon, featured = false } = Astro.props;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class:list={[
    "group relative block w-full no-underline transition-all duration-300 transform hover:-translate-y-1",
    featured ? "mb-6" : "mb-4"
  ]}
>
  <div
    class:list={[
      "relative overflow-hidden rounded-2xl p-5 border shadow-sm transition-all duration-300",
      featured 
        ? "bg-gradient-to-br from-blue-600 to-sky-500 border-transparent text-white shadow-blue-200/50 hover:shadow-blue-300/60" 
        : "bg-white/70 backdrop-blur-md border-neutral-200/80 text-neutral-900 shadow-neutral-100/50 hover:border-blue-400/50 hover:shadow-blue-100/50"
    ]}
  >
    <!-- Background Glow Effect -->
    <div class="absolute -inset-2 bg-gradient-to-r from-blue-400 to-sky-400 opacity-0 blur group-hover:opacity-10 transition duration-500"></div>

    <div class="relative flex items-center gap-4">
      {icon && (
        <div class:list={[
          "flex h-12 w-12 shrink-0 items-center justify-center rounded-xl text-2xl",
          featured ? "bg-white/20" : "bg-neutral-100 group-hover:bg-blue-50 group-hover:text-blue-600 transition-colors"
        ]}>
          {icon}
        </div>
      )}
      <div class="flex-grow">
        <h3 class:list={[
          "text-lg font-bold leading-tight",
          featured ? "text-white" : "text-neutral-900"
        ]}>
          {title}
        </h3>
        {subtitle && (
          <p class:list={[
            "mt-0.5 text-sm font-medium",
            featured ? "text-white/70" : "text-neutral-500"
          ]}>
            {subtitle}
          </p>
        )}
        {description && (
          <p class:list={[
            "mt-1 text-sm leading-relaxed",
            featured ? "text-white/80" : "text-neutral-600"
          ]}>
            {description}
          </p>
        )}
      </div>
      <div class:list={[
        "flex h-8 w-8 items-center justify-center rounded-full transition-transform duration-300 group-hover:translate-x-1",
        featured ? "bg-white/20 text-white" : "bg-neutral-100 text-neutral-400 group-hover:bg-blue-600 group-hover:text-white"
      ]}>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14m-7-7 7 7-7 7"/>
        </svg>
      </div>
    </div>
  </div>
</a>

<style>
  .group:hover h3 {
    @apply transition-colors duration-300;
  }
</style>
