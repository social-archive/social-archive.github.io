---
interface Props {
  href: string;
  title: string;
  subtitle?: string;
  description?: string;
  icon?: string;
  featured?: boolean;
  bgColor?: string;
}

const { 
  href, 
  title, 
  subtitle, 
  description, 
  icon, 
  featured = false,
  bgColor = "bg-white"
} = Astro.props;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class:list={[
    "group relative block w-full no-underline transition-all duration-200",
    featured ? "mb-6" : "mb-4"
  ]}
>
  <div
    class:list={[
      "neo-brutalism relative overflow-hidden rounded-xl p-5",
      featured ? "bg-brutal-pink" : bgColor
    ]}
  >
    <div class="relative flex items-center gap-4">
      {icon && (
        <div class:list={[
          "flex h-12 w-12 shrink-0 items-center justify-center rounded-lg text-2xl border-2 border-black bg-white shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]",
        ]}>
          {icon}
        </div>
      )}
      <div class="flex-grow">
        <h3 class="text-lg font-[900] leading-tight text-black">
          {title}
        </h3>
        {subtitle && (
          <p class="mt-0.5 text-sm font-bold text-black/70">
            {subtitle}
          </p>
        )}
        {description && (
          <p class="mt-1 text-sm leading-relaxed text-black/60 font-medium">
            {description}
          </p>
        )}
      </div>
      <div class="flex h-8 w-8 items-center justify-center rounded-full border-2 border-black bg-white shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] transition-transform duration-200 group-hover:bg-black group-hover:text-white">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14m-7-7 7 7-7 7"/>
        </svg>
      </div>
    </div>
  </div>
</a>
